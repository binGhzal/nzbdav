{
  "name": "nzb-webdav",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "allowScripts": {
    "@parcel/watcher": false,
    "esbuild": false,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  },
  "scripts": {
    "build": "react-router build",
    "build:server": "tsc -p tsconfig.node.json --outDir dist-node",
    "dev": "cross-env NODE_ENV=development PORT=5173 tsx server.ts",
    "start": "node dist-node/server.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "react-router typegen && tsc -b"
  },
  "dependencies": {
    "@react-router/express": "^7.16.0",
    "@react-router/fs-routes": "^7.16.0",
    "@react-router/node": "^7.5.3",
    "bootstrap": "^5.3.8",
    "compression": "^1.7.5",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.1.1",
    "isbot": "^5.1.44",
    "mime-types": "^3.0.2",
    "morgan": "^1.11.0",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "react-dropzone": "^15.0.0",
    "react-router": "^7.5.3",
    "remix-auth": "^4.2.0",
    "remix-auth-form": "^3.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@react-router/dev": "^7.5.3",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/mime-types": "^3.0.1",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "sass": "^1.101.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "http-proxy-middleware": {
      "http-proxy": "npm:http-proxy-node16@^1.0.6"
    }
  }
}
