{
  "extends": "./tsconfig.json",
  "include": [
    "bootstrap.ts",
    "server.ts",
    "server/debug-output.ts",
    "server/public-failure-response.ts",
    "server/react-router-handler.ts",
    "server/request-policy.ts",
    "server/websocket-policy.ts",
    "app/utils/public-failure.ts",
    "vite.config.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  }
}
