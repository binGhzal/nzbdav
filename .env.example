# Runtime identity
PUID=1000
PGID=1000
TZ=Etc/UTC

# Paths and bind addresses
CONFIG_PATH=/config
MOUNT_DIR=/mnt/remote/nzbdav
LISTEN_ADDRESS=0.0.0.0
# BACKEND_URL is normally derived by entrypoint.sh.
# BACKEND_URL=http://localhost:8080
URL_BASE=

# Database provider. SQLite is the default and stores /config/db.sqlite.
# PostgreSQL is intended for new installs unless you manually migrate data.
NZBDAV_DATABASE_PROVIDER=sqlite
# NZBDAV_DATABASE_PROVIDER=postgres
# NZBDAV_DATABASE_CONNECTION_STRING=Host=postgres;Port=5432;Database=nzbdav;Username=nzbdav;Password=replace-with-db-password

# Internal frontend-to-backend API key.
# Generate a long random value; do not reuse this placeholder.
FRONTEND_BACKEND_API_KEY=replace-with-random-hex

# Initial WebDAV/admin credentials used before settings are saved in the UI.
WEBDAV_USER=admin
WEBDAV_PASSWORD=replace-with-admin-password

# Optional SAB/API defaults.
CATEGORIES=movies,tv
NZB_GRAB_USER_AGENT=NZBDav
# Optional CPU target for adaptive throttling. Omit to use a multicore-aware default.
# NZBDAV_ADAPTIVE_CPU_TARGET_CORES=2
# Optional: make generated .rclonelink/DFS symlink targets relative to the
# completed-symlinks entry. Use only when host/container absolute mount paths
# differ. Values: absolute, relative.
# NZBDAV_SYMLINK_TARGET_MODE=absolute

# Mount backend. Keep rclone as the default until DFS benchmark artifacts pass
# the documented gate. DFS is a Linux x64 prototype. Values: rclone, dfs, none.
MOUNT_TYPE=rclone
# Optional cross-backend mount directory override. Defaults to MOUNT_DIR.
# Mount:Directory is also supported in app config.
# MOUNT_DIRECTORY=/mnt/remote/nzbdav

# Temporary sparse segment cache is configured in-app, not through env vars.
# Defaults: cache.enabled=true, cache.directory=/config/cache/segments,
# cache.max-bytes=68719476736, cache.chunk-bytes=4194304,
# cache.read-ahead-bytes=8388608, cache.idle-ttl=00:10:00.

# Repair workers are configured in-app.
# Defaults: repair.enable=false, repair.healthcheck-concurrency=50,
# repair.connection-budget-percent=20.

# Usenet providers. Keep this JSON on one line when used in an env file.
# Ports 563 and 443 are treated as TLS even if imported JSON forgets useSsl=true.
NZBDAV_USENET_PROVIDERS_JSON=[{"name":"primary","host":"news.example.com","port":563,"useSsl":true,"username":"replace-with-user","password":"replace-with-password","connections":50,"priority":0}]

# ARR instances are normally configured in the WebUI under Settings > Radarr/Sonarr.
# ARR-driven priority and search nudging are stored in the arr.instances app config.
# Defaults are safe: Prioritization.Enabled=false, Prioritization.Mode=report,
# SearchNudge.Enabled=false, SearchNudge.Mode=report.

# Logging and version metadata
LOG_LEVEL=warning
NZBDAV_VERSION=local
